# ============================================================
# GlobeCase — PRODUCTION env for docker-compose on your VPS.
# Copy to `.env.production`, fill in real values, keep it OFF git.
# Generate secrets with:
#   openssl rand -base64 48
# ============================================================

# Public URL (your real domain, https once TLS is live)
NEXT_PUBLIC_SITE_URL="https://globe-case.com"
NODE_ENV="production"

# --- Postgres (compose service `db`) ---
POSTGRES_USER="globecase"
POSTGRES_PASSWORD="CHANGE_ME_strong_db_password"
POSTGRES_DB="globecase"
# Host is the compose service name `db`, not localhost.
DATABASE_URL="postgresql://globecase:CHANGE_ME_strong_db_password@db:5432/globecase?schema=public"

# --- Admin bootstrap (created/kept by the seed step) ---
AUTH_SECRET="CHANGE_ME_openssl_rand_base64_48"
ADMIN_EMAIL="owner@globe-case.com"
ADMIN_PASSWORD="CHANGE_ME_strong_admin_password"

# --- Stripe (LIVE or TEST keys) ---
STRIPE_SECRET_KEY="sk_test_or_live_key"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_or_live_key"
STRIPE_WEBHOOK_SECRET="whsec_from_dashboard_endpoint"

# --- Store ---
STORE_CURRENCY="eur"
STORE_DEFAULT_PRICE_CENTS="2000"
STORE_SUPPORT_EMAIL="support@globe-case.com"

# --- Email (Resend SMTP, outbound order confirmations/updates) ---
# SMTP_USER is literally "resend"; SMTP_PASS is your Resend API key (re_...).
SMTP_HOST="smtp.resend.com"
SMTP_PORT="465"
SMTP_USER="resend"
SMTP_PASS="re_your_resend_api_key"
SMTP_SECURE="true"
MAIL_FROM="GlobeCase <orders@globe-case.com>"
# Your PRIVATE inbox for new-order alerts (never shown to customers). Fill on the server only.
OWNER_EMAIL="your-private-inbox@example.com"

# Re-run the idempotent catalog seed on each deploy (safe). Set false to skip.
SEED_ON_DEPLOY="true"

# Optional AI
GEMINI_API_KEY=""
