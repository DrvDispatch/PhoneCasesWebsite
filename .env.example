# ============================================================
# GlobeCase — environment configuration
# Copy this file to `.env` for local dev and `.env.production` on the server.
# NEVER commit the filled-in versions.
# ============================================================

# --- Core ---
# Public base URL of the site (no trailing slash). Used for canonical URLs,
# sitemap, OpenGraph, and Stripe success/cancel redirects.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NODE_ENV="development"

# --- Database (PostgreSQL) ---
# Local dev example. In Docker Compose this is set to the `db` service host.
DATABASE_URL="postgresql://globecase:globecase@localhost:5432/globecase?schema=public"

# --- Admin auth ---
# Secret used to sign admin session JWTs. Generate a strong one:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET="dev-only-insecure-secret-change-me-please-0000000000000000"
# Bootstrap admin account created by `npm run db:seed`.
ADMIN_EMAIL="admin@globe-case.com"
ADMIN_PASSWORD="ChangeMe!Admin123"

# --- Stripe (TEST placeholder keys — replace with your own) ---
# Get keys at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_PLACEHOLDER_replace_me"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_PLACEHOLDER_replace_me"
# Webhook signing secret from `stripe listen` or the dashboard endpoint.
STRIPE_WEBHOOK_SECRET="whsec_PLACEHOLDER_replace_me"

# --- Store config ---
STORE_CURRENCY="eur"
STORE_DEFAULT_PRICE_CENTS="2000"
STORE_SUPPORT_EMAIL="support@globe-case.com"

# --- Email (Resend SMTP, outbound order confirmations/updates) ---
# Leave SMTP_PASS blank to disable email (no crash).
# SMTP_USER is literally "resend"; SMTP_PASS is your Resend API key (re_...).
SMTP_HOST="smtp.resend.com"
SMTP_PORT="465"
SMTP_USER="resend"
SMTP_PASS=""
SMTP_SECURE="true"
MAIL_FROM="GlobeCase <orders@globe-case.com>"
# Where new-order alerts are sent (your own inbox).
OWNER_EMAIL=""

# --- Optional: Gemini (AI content generation for product copy) ---
# Leave blank to disable AI features.
GEMINI_API_KEY=""
