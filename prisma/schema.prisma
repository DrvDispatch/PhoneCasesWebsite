// GlobeCase — data model
// PostgreSQL + Prisma. Money is stored in integer cents to avoid float error.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// A world region shown on the storefront (Kavkaz, Europe, ...).
model Region {
  id        String    @id @default(cuid())
  slug      String    @unique
  name      String
  blurb     String?
  image     String?
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]

  @@index([sortOrder])
}

/// One product = one country's phone case (e.g. "Chechnya Phone Case").
model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  countryCode String? // ISO-ish tag for the country, optional
  description String
  /// Price in the smallest currency unit (cents). Default €20.00 = 2000.
  priceCents  Int      @default(2000)
  currency    String   @default("eur")
  image       String?
  /// Extra product photos for the gallery/carousel (#6).
  gallery     String[] @default([])
  /// Selectable design options shown as thumbnails on the product page (#13).
  designImages String[] @default([])
  /// How the main image is displayed: "contain" (whole image) or "cover" (fill/crop).
  imageFit    String   @default("contain")
  /// Perceived zoom of the main image, percent (50-160).
  imageScale  Int      @default(100)
  /// Background colour behind the image (for letterboxed "contain" mode).
  imageBg     String   @default("#f7f8f9")
  /// null stock = made-to-order / unlimited. A number tracks inventory.
  stock       Int?
  active      Boolean  @default(true)
  featured    Boolean  @default(false)
  sortOrder   Int      @default(0)

  regionId String
  region   Region @relation(fields: [regionId], references: [id], onDelete: Cascade)

  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([regionId])
  @@index([active, featured])
  @@index([slug])
}

enum OrderStatus {
  PENDING // checkout session created, not yet paid
  PAID // payment confirmed via Stripe webhook
  FULFILLED // shipped
  CANCELLED
  REFUNDED
}

/// A customer order, created from a Stripe Checkout session.
model Order {
  id              String      @id @default(cuid())
  /// Human-friendly order number, e.g. GC-2CQ4X7.
  number          String      @unique
  status          OrderStatus @default(PENDING)
  email           String?
  customerName    String?
  shippingAddress Json?
  /// Snapshot totals (cents).
  subtotalCents   Int         @default(0)
  discountCents   Int         @default(0)
  totalCents      Int         @default(0)
  currency        String      @default("eur")
  /// Promo code applied to this order, if any (#4).
  promoCode       String?

  stripeSessionId       String? @unique
  stripePaymentIntentId String?

  // Fulfillment
  carrier        String?
  trackingNumber String?
  trackingUrl    String?
  notes          String?

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  paidAt    DateTime?
  fulfilledAt DateTime?

  @@index([status])
  @@index([createdAt])
  @@index([email])
}

/// A line in an order. Product fields are snapshotted so history is stable
/// even if the product is later edited or deleted.
model OrderItem {
  id         String @id @default(cuid())
  orderId    String
  order      Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId  String?
  product    Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  name       String
  slug       String
  priceCents Int
  quantity   Int    @default(1)
  /// Device the case is for (e.g. "iPhone 15 Pro").
  phoneModel String?
  /// Device brand (e.g. "Apple", "Samsung") (#18).
  phoneBrand String?
  /// Chosen design option, e.g. "Design 2" (#13).
  designChoice String?

  @@index([orderId])
}

enum AdminRole {
  OWNER
  STAFF
}

/// Back-office user for the /admin panel.
model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  role         AdminRole @default(STAFF)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

/// First-party product reviews (in addition to the embedded social widget).
model Review {
  id          String   @id @default(cuid())
  author      String
  rating      Int // 1..5
  body        String
  productSlug String?
  /// Optional photo (e.g. from a Google review) (#11/#21).
  imageUrl    String?
  /// Reviewer profile picture (e.g. Google avatar).
  avatarUrl   String?
  /// Photos the reviewer attached.
  photos      String[] @default([])
  /// Display date label like "a year ago" (from the source).
  dateLabel   String?
  approved    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([approved])
}

enum DiscountKind {
  PERCENT
  FIXED
}

/// Admin-managed promo code applied on our own cart, before Stripe (#4).
model PromoCode {
  id               String       @id @default(cuid())
  code             String       @unique
  kind             DiscountKind @default(PERCENT)
  /// Percent (1-100) when PERCENT, else a fixed amount in cents.
  value            Int
  active           Boolean      @default(true)
  minSubtotalCents Int?
  maxRedemptions   Int?
  timesRedeemed    Int          @default(0)
  expiresAt        DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([active])
}

/// Newsletter subscriber captured by the 5%-off signup (#22).
model Subscriber {
  id         String   @id @default(cuid())
  email      String   @unique
  /// The 5%-off code issued to this subscriber.
  code       String?
  unsubToken String   @unique
  active     Boolean  @default(true)
  source     String?  @default("popup")
  createdAt  DateTime @default(now())

  @@index([active])
}

/// Append-only audit log for sensitive admin actions.
model AuditLog {
  id        String   @id @default(cuid())
  actor     String
  action    String
  target    String?
  meta      Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

/// Editable content page (About, policies, custom) — a lightweight CMS.
model Page {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  body      String // HTML
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Simple key/value store settings (owner email, shipping note, etc.).
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

/// Point-in-time backup of the product catalogue (auto before AI changes, or manual).
/// Enables one-click restore/undo. `data` holds the full product rows as JSON.
model Snapshot {
  id           String   @id @default(cuid())
  label        String
  productCount Int      @default(0)
  data         Json
  createdAt    DateTime @default(now())

  @@index([createdAt])
}
